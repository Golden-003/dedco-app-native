# ============================================================
# DEDCO — Variables d'environnement (exemple)
# Copiez ce fichier en .env et adaptez les valeurs
# ============================================================

# Base de données SQLite (développement local)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Production : remplacez par une vraie base PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dedco

# Clés API (à ajouter en production)
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
